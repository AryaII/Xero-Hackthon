# --- Xero (Custom Connection app — single org) ---
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# Optional: override the scopes the MCP server requests (space-separated).
# Leave blank to use the app's configured scopes.
XERO_SCOPES=accounting.reports.aged.read accounting.reports.profitandloss.read accounting.contacts.read accounting.settings.read accounting.banktransactions.read accounting.invoices accounting.invoices.read

# --- LLM for the Orient (reasoning) step ---
# Set LLM_PROVIDER to whichever key you provide below (anthropic | openai)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                 # only needed for the Option B agent enhancement

# --- App ---
# true = serve captured fixtures, no Xero calls (offline demo)
DEMO_MODE=false
PORT=8787
