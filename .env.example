# --- Xero (Custom Connection app — single org) ---
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# This is what actually gets REQUESTED from Xero at token time — it's an
# override, not just a filter on what your Custom Connection app is authorized
# for. If a report call fails with a generic Xero error, check this list before
# assuming the app itself is missing a scope.
XERO_SCOPES=accounting.reports.aged.read accounting.reports.profitandloss.read accounting.reports.balancesheet.read accounting.reports.trialbalance.read accounting.reports.banksummary.read accounting.contacts.read accounting.settings.read accounting.banktransactions.read accounting.invoices accounting.invoices.read

# --- LLM for the Orient (reasoning) step ---
# Set LLM_PROVIDER to whichever key you provide below (anthropic | openai)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                 # only needed for the Option B agent enhancement

# --- App ---
# true = serve captured fixtures, no Xero calls (offline demo)
DEMO_MODE=false
PORT=8787
